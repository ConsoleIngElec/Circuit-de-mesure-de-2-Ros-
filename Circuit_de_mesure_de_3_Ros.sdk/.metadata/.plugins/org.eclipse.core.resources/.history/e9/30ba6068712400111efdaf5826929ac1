#include <stdio.h>
#include "xil_io.h"
#include "xparameters.h"

// Remplace par tes adresses réelles définies dans xparameters.h
#define BASE_ADDR_IP_CONV  XPAR_IP_CONVERSION_0_S00_AXI_BASEADDR

// Offsets (à adapter selon ton design Vivado)
#define REG_DATA_OFFSET    0  // Registre où arrive la donnée du RO
#define REG_ALLOW_OFFSET   4  // Registre qui lit le signal Allow
#define REG_DONE_OFFSET    8  // Registre pour envoyer le signal Done

void read_frequencies() {
    uint32_t f_ro[4]; // Tableau pour stocker les 4 RO du mode en cours

    printf("\n--- Demarrage du systeme de mesure ---\n");

    for (int k = 0; k < 6; k++) {
        printf("\n>>> [DEBUG] ATTENTE MODE k=%d (50s)...\n", k);

        // 1. On attend que le FPGA lève le signal Allow (Seconde 25)
        while ((Xil_In32(BASE_ADDR_IP_CONV + REG_ALLOW_OFFSET) & 0x01) == 0) {
            // On peut ajouter un petit sleep ou laisser vide pour une réactivité max
        }

        printf("  [DEBUG] Signal Allow detecte ! Lecture des 4 RO...\n");

        // 2. Lecture des 4 RO pour ce mode
        for (int ro_idx = 0; ro_idx < 4; ro_idx++) {

            // On lit la donnée présente sur le bus
            f_ro[ro_idx] = Xil_In32(BASE_ADDR_IP_CONV + REG_DATA_OFFSET);

            // On envoie le pulse DONE pour dire au FPGA de passer à l'octet/RO suivant
            Xil_Out32(BASE_ADDR_IP_CONV + REG_DONE_OFFSET, 1);
            Xil_Out32(BASE_ADDR_IP_CONV + REG_DONE_OFFSET, 0);

            // Petite attente pour laisser la FSM du FPGA changer d'état
            for(int i=0; i<100; i++);
        }

        // 3. Affichage des résultats pour ce mode
        printf("  ======================================\n");
        printf("  RESULTATS MODE %d :\n", k);
        for (int i = 0; i < 4; i++) {
            printf("    - RO #%d : %u Hz\n", (k * 4) + i, f_ro[i]);
        }
        printf("  ======================================\n");

        // On attend que Allow redescende avant de boucler sur le k suivant
        while ((Xil_In32(BASE_ADDR_IP_CONV + REG_ALLOW_OFFSET) & 0x01) == 1);
    }

    printf("\n>>> FIN DU CYCLE DE MESURE DES 24 RO.\n");
}
