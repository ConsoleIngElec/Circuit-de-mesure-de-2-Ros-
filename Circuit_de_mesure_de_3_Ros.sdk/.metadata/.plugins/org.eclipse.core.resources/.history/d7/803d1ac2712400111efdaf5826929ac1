#include <stdio.h>
#include <string.h>
#include "xparameters.h"
#include "xil_io.h"
#include "sleep.h"
#include "ff.h"
#include "xstatus.h"

// --- VERIFIE CETTE ADRESSE DANS TON ADDRESS EDITOR VIVADO ---
#define BASE_ADDR XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR

static FATFS fatfs;
FIL myFile;
FRESULT res;
UINT bw;

int main() {
    u32 brute_val;
    u32 ro_32bit;
    float freq_mhz;
    int cycle = 0;
    char buffer_sd[2048];
    char *filename = "STRESS_24RO.CSV";

    printf("\n\r=== [DEBUG START] DEMARRAGE DU SYSTEME ===\n\r");

    // 1. TEST CARTE SD
    printf("[DEBUG] Tentative de montage SD...\n\r");
    res = f_mount(&fatfs, "0:/", 1);
    if (res != FR_OK) {
        printf("[DEBUG] ECHEC SD (Code: %d). Verifie le formatage FAT32.\n\r", res);
    } else {
        printf("[DEBUG] SD MONTEE AVEC SUCCES.\n\r");

        res = f_open(&myFile, filename, FA_OPEN_ALWAYS | FA_WRITE);
        if (res == FR_OK) {
            if (f_size(&myFile) == 0) {
                strcpy(buffer_sd, "Cycle;Temps");
                for(int i=0; i<24; i++) {
                    sprintf(buffer_sd + strlen(buffer_sd), ";RO_%d_MHz", i);
                }
                strcat(buffer_sd, "\n");
                f_write(&myFile, buffer_sd, strlen(buffer_sd), &bw);
            }
            f_close(&myFile);
            printf("[DEBUG] FICHIER SD PRET.\n\r");
        }
    }

    while(1) {
        printf("\n\r>>> [DEBUG] DEBUT CYCLE N %03d\n\r", cycle);
        sprintf(buffer_sd, "%d;%02d:%02d:%02d", cycle, (cycle*600)/3600, ((cycle*600)%3600)/60, (cycle*600)%60);

        for (int k = 0; k < 6; k++) {
            printf("  [DEBUG] Attente Mode k=%d...\n\r", k);

            for (int i = 0; i < 4; i++) {
                ro_32bit = 0;

                for (int byte = 0; byte < 4; byte++) {
                    // --- POINT DE BLOCAGE NUMERO 1 ---
                    // Si le code s'arrete ici, c'est que le signal 'Allow' (slv_reg1) ne monte jamais.
                    int timeout = 0;
                    while ((Xil_In32(BASE_ADDR + 4) & 0x01) == 0) {
                        timeout++;
                        if (timeout > 10000000) { // Petit heartbeat pour voir que le CPU tourne
                            printf("    [DEBUG] Toujours en attente de Allow (Mode:%d RO:%d Byte:%d)...\n\r", k, i, byte);
                            timeout = 0;
                        }
                    }

                    // Lecture
                    brute_val = (Xil_In32(BASE_ADDR + 0) & 0xFF);
                    ro_32bit |= (brute_val << (byte * 8));

                    // --- POINT DE BLOCAGE NUMERO 2 ---
                    // Envoi du DONE (slv_reg2).
                    // Si le fil n'est pas branche dans Vivado, le FPGA ne baissera jamais 'Allow'.
                    Xil_Out32(BASE_ADDR + 8, 1);
                    Xil_Out32(BASE_ADDR + 8, 0);
                }

                freq_mhz = (float)ro_32bit / 1000000.0f;
                sprintf(buffer_sd + strlen(buffer_sd), ";%.3f", freq_mhz);
            }
            printf("  [DEBUG] Mode k=%d LU OK.\n\r", k);
        }

        strcat(buffer_sd, "\n");

        // Sauvegarde SD
        res = f_open(&myFile, filename, FA_OPEN_APPEND | FA_WRITE);
        if (res == FR_OK) {
            f_write(&myFile, buffer_sd, strlen(buffer_sd), &bw);
            f_close(&myFile);
            printf("[DEBUG] SAUVEGARDE SD TERMINEE.\n\r");
        } else {
            printf("[DEBUG] ERREUR ECRITURE SD.\n\r");
        }

        cycle++;
    }
    return 0;
}
