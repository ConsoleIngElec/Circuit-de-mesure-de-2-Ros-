#include <stdio.h>
#include <string.h>
#include "xparameters.h"
#include "xil_io.h"
#include "sleep.h"
#include "ff.h"      // Bibliothčque pour la carte SD
#include "xstatus.h"

// Adresse de ton IP (Vérifie bien ce nom dans xparameters.h)
#define BASE_ADDR XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR

// --- OBJETS GLOBAUX POUR LA CARTE SD ---
static FATFS fatfs;
FIL myFile;
FRESULT res;
UINT bw;

int main() {
    // --- DÉCLARATION DES VARIABLES (Celles qui manquaillerent) ---
    u32 brute_val;
    float freq_mhz;
    int cycle = 0;
    int total_sec;
    int hh, mm, ss;
    char buffer_sd[2048]; // Taille augmentée pour 24 colonnes
    char *filename = "STRESS_24RO.CSV";

    printf("======================================================\n");
    printf("   MONITORING 24 OSCILLATEURS (6 MODES x 4 RO)       \n");
    printf("======================================================\n\n");

    // 1. Montage de la carte SD
    res = f_mount(&fatfs, "0:/", 1);
    if (res != FR_OK) {
        printf("ERREUR : Impossible de monter la carte SD (Code: %d)\n", res);
    } else {
        printf("Carte SD detectee et montee avec succes !\n");

        // 2. Création de l'entęte du fichier (si c'est un nouveau fichier)
        res = f_open(&myFile, filename, FA_OPEN_ALWAYS | FA_WRITE);
        if (res == FR_OK) {
            if (f_size(&myFile) == 0) {
                // On écrit : Cycle;Temps;RO_0;RO_1;...;RO_23
                strcpy(buffer_sd, "Cycle;Temps");
                for(int i=0; i<24; i++) {
                    sprintf(buffer_sd + strlen(buffer_sd), ";RO_%d_MHz", i);
                }
                strcat(buffer_sd, "\n");
                f_write(&myFile, buffer_sd, strlen(buffer_sd), &bw);
            }
            f_close(&myFile);
            printf("Fichier %s pret.\n", filename);
        }
    }

    while(1) {
        // --- CALCUL DU TEMPS (Cycle de 10 minutes = 600s) ---
        total_sec = cycle * 600;
        hh = total_sec / 3600;
        mm = (total_sec % 3600) / 60;
        ss = total_sec % 60;

        printf("\n>>> CYCLE N %03d | TEMPS : %02d:%02d:%02d\n", cycle, hh, mm, ss);

        // On commence la ligne avec le cycle et le temps
        sprintf(buffer_sd, "%d;%02d:%02d:%02d", cycle, hh, mm, ss);

        // --- BOUCLE POUR LES 6 MODES (k de 0 ŕ 5) ---
        for (int k = 0; k < 6; k++) {

            // --- BOUCLE POUR LES 4 RO PAR MODE ---
            for (int i = 0; i < 4; i++) {

                // Attente du signal 'Send' du FPGA
                while ((Xil_In32(BASE_ADDR + 4) & 0x01) == 0);

                u32 ro_32bit = 0;
                // Lecture des 4 octets (32 bits)
                for (int byte = 0; byte < 4; byte++) {
                    while ((Xil_In32(BASE_ADDR + 4) & 0x01) == 0);
                    brute_val = (Xil_In32(BASE_ADDR + 0) & 0xFF);
                    ro_32bit |= (brute_val << (byte * 8));

                    // Handshake DONE vers FPGA
                    Xil_Out32(BASE_ADDR + 8, 1);
                    Xil_Out32(BASE_ADDR + 8, 0);
                }

                freq_mhz = (float)ro_32bit / 1000000.0f;

                // Ajout de la fréquence dans le buffer SD
                sprintf(buffer_sd + strlen(buffer_sd), ";%.3f", freq_mhz);
            }
            printf("  Mode k=%d lu (4 ROs).\n", k);
        }

        // Fin de la ligne
        strcat(buffer_sd, "\n");

        // 3. ECRITURE SUR LA CARTE SD
        res = f_open(&myFile, filename, FA_OPEN_APPEND | FA_WRITE);
        if (res == FR_OK) {
            f_write(&myFile, buffer_sd, strlen(buffer_sd), &bw);
            f_close(&myFile);
            printf(">> Sauvegarde SD OK (24 ROs enregistres).\n");
        } else {
            printf(">> ERREUR SD : Impossible d'ecrire.\n");
        }

        cycle++;
        // Le systčme attendra naturellement le prochain cycle via le 'while' du Send
    }

    return 0;
}
