#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

static FATFS fatfs;
char *log_file = "Veillissement.csv";
int sd_is_available = 0;

// --- FONCTION D'ECRITURE ROBUSTE ---
void write_to_sd(char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    // On ne tente l'ouverture que si le montage a rťussi un jour
    // FA_OPEN_ALWAYS permet de crťer le fichier s'il n'existe pas
    res = f_open(&fil, log_file, FA_WRITE | FA_OPEN_APPEND);

    if (res == FR_OK) {
        f_write(&fil, data, strlen(data), &bw);
        f_sync(&fil); // Force l'enregistrement sur le disque
        f_close(&fil);
        if (sd_is_available == 0) {
            printf("  [INFO] Carte SD operationnelle.\n");
            sd_is_available = 1;
        }
    } else {
        if (sd_is_available == 1) {
            printf("  [ERREUR] Ecriture SD impossible. Mode console uniquement.\n");
            sd_is_available = 0;
        }
        // On dťmonte pour purger les erreurs logicielles
        f_mount(NULL, "0:/", 0);
    }
}

int main() {
    init_platform();
    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[512], time_str[40], mode_label[20];
    XTime tStart, tNow;

    printf("\n--- DEMARRAGE DU BANC DE TEST ---\n");

    // Tentative de montage initial (On ne bloque pas si Áa rate)
    if (f_mount(&fatfs, "0:/", 1) == FR_OK) {
        sd_is_available = 1;
        write_to_sd("Cycle;Temps_Texte;Temps_Sec;Mode;Label;RO_Global_ID;Freq_MHz\n");
    } else {
        printf("[ATTENTION] SD absente au boot. Lancement console...\n");
        sd_is_available = 0;
    }

    XTime_GetTime(&tStart);

    while(1) {
        printf("\n\n>>> CYCLE %06d\n", cycle_count);

        for (k = 0; k < 6; k++) {

            // Tentative de re-montage discret si la carte ťtait absente
            if (sd_is_available == 0) {
                f_mount(&fatfs, "0:/", 0); // Montage rapide
            }

            // ATTENTE DU SIGNAL FPGA
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;

            // Formatage temps JJ:HH:MM:SS
            int d = (int)elapsed / 86400;
            int h = ((int)elapsed % 86400) / 3600;
            int m = ((int)elapsed % 3600) / 60;
            int s = (int)elapsed % 60;
            sprintf(time_str, "%02dj:%02dh:%02dm:%02ds", d, h, m, s);

            if (k < 3) sprintf(mode_label, "RO_B %d", k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE %s | %s\n", time_str, mode_label);
            printf("  --------------------------------------\n");

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                float freq_mhz = (float)frequency_32bit / 1000000.0;
                int global_id = (k * 4) + ro_idx + 1;

                // AFFICHAGE TOUJOURS ACTIF
                printf("    RO %d : %.3f MHz\n", global_id, freq_mhz);

                // ECRITURE (Ne bloque pas si SD absente)
                sprintf(buffer, "%d;%s;%.0f;Mode %d;%s;RO %d;%.3f\n",
                        cycle_count, time_str, elapsed, k + 1, mode_label, global_id, freq_mhz);
                write_to_sd(buffer);
            }

            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }
        cycle_count++;
    }
    return 0;
}
