#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

static FATFS fatfs;
char *log_file = "Mesures_RO.csv";
int sd_status = 0; // 0: Absent/Erreur, 1: OK

// --- FONCTION D'ECRITURE HYPER-SECURISEE ---
void safe_write_sd(char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    // On tente d'ouvrir. Si la carte n'est pas lŕ, f_open doit échouer VITE.
    res = f_open(&fil, log_file, FA_WRITE | FA_OPEN_APPEND);

    if (res == FR_OK) {
        f_write(&fil, data, strlen(data), &bw);
        f_sync(&fil); // On force l'ecriture sur les secteurs
        f_close(&fil);
        sd_status = 1;
    } else {
        // Si ça rate, on marque la SD comme HS pour ne pas insister
        if (sd_status == 1) {
            printf("\n  [!] SD DECONNECTEE - Passage en mode console pure.\n");
        }
        sd_status = 0;
        f_mount(NULL, "0:/", 0); // On libčre le bus immédiatement
    }
}

int main() {
    init_platform();
    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[512], time_str[40], mode_label[20];
    XTime tStart, tNow;

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs    *\n");
    printf("******************************************************\n");

    // On attend que la tension se stabilise
    sleep(2);

    XTime_GetTime(&tStart);

    while(1) {
        // Tentative de montage au début de chaque cycle seulement
        if (sd_status == 0) {
            if (f_mount(&fatfs, "0:/", 0) == FR_OK) {
                sd_status = 1;
                printf("[SD] Carte detectee et montee.\n");
                safe_write_sd("Cycle;Temps;Mode;RO_ID;Freq_MHz\n");
            }
        }

        printf("\n>>> DEBUT DU CYCLE N %06d\n", cycle_count);

        for (k = 0; k < 6; k++) {
            // 1. ATTENTE SIGNAL FPGA (Ne dépend pas de la SD)
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;

            // Formatage temps simple
            int h = (int)elapsed / 3600;
            int m = ((int)elapsed % 3600) / 60;
            int s = (int)elapsed % 60;
            sprintf(time_str, "%02dh:%02dm:%02ds", h, m, s);

            if (k < 3) sprintf(mode_label, "RO_B %d", k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE | %s | %s\n", time_str, mode_label);

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;

                // 2. LECTURE DES REGISTRES (Priorité 1)
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                float freq_mhz = (float)frequency_32bit / 1000000.0;
                int global_id = (k * 4) + ro_idx + 1;

                // 3. AFFICHAGE CONSOLE (Priorité 2)
                printf("    RO %d : %.3f MHz\n", global_id, freq_mhz);

                // 4. ECRITURE SD (Priorité 3 - Uniquement si SD OK)
                if (sd_status == 1) {
                    sprintf(buffer, "%d;%s;Mode %d;RO %d;%.3f\n",
                            cycle_count, time_str, k + 1, global_id, freq_mhz);
                    safe_write_sd(buffer);
                }
            }

            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }
        cycle_count++;
    }

    cleanup_platform();
    return 0;
}
