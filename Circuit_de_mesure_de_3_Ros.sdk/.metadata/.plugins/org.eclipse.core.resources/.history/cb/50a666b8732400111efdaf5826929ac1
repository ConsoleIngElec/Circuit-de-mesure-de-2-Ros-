#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xparameters.h"
#include "xil_io.h"

// --- DEFINITIONS DES ADRESSES ---
#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR

// Offsets des registres (slv_reg0, slv_reg1, slv_reg2 dans ton IP AXI)
#define REG_DATA_OFFSET    0   // slv_reg0 : DonnÕes venant du FPGA
#define REG_ALLOW_OFFSET   4   // slv_reg1 : Signal 'Allow' (Bit 0)
#define REG_DONE_OFFSET    8   // slv_reg2 : Signal 'Done' (Ecriture)

int main() {
    init_platform();

    u32 frequency_data;
    u32 allow_signal;
    int k, ro_idx;

    printf("\n======================================================\n");
    printf("   MONITORING 24 OSCILLATEURS (6 MODES x 4 RO)       \n");
    printf("======================================================\n");

    while(1) { // Boucle infinie pour les cycles de mesure

        for (k = 0; k < 6; k++) {
            printf("\n>>> [SYSTEME] Attente du Mode k=%d (Phase de chauffe)...\n", k);

            // 1. Attente bloquante du signal Allow (Seconde 25 dans le FPGA)
            do {
                allow_signal = Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET);
            } while ((allow_signal & 0x01) == 0);

            printf("  [CAPTURED] Donnees prõtes ! Lecture des 4 RO du mode %d :\n", k);
            printf("  --------------------------------------------------\n");

            // 2. Lecture des 4 RO pour ce mode spÕcifique
            for (ro_idx = 0; ro_idx < 4; ro_idx++) {

                // Lecture de la valeur du compteur sur le bus
                frequency_data = Xil_In32(BASE_ADDR + REG_DATA_OFFSET);

                // Affichage propre
                printf("    RO #%02d : %lu Hz\n", (k * 4) + ro_idx, frequency_data);

                // 3. Handshake : On envoie 'Done' au FPGA pour passer au RO suivant
                Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1); // Done = 1
                Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0); // Done = 0 (Pulse)

                // Petite pause technique pour laisser le FPGA changer d'Õtat
                for(volatile int i = 0; i < 500; i++);
            }
            printf("  --------------------------------------------------\n");

            // 4. SecuritÕ : On attend que le FPGA repasse Allow Á 0
            // pour ne pas relire le mõme mode en boucle.
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        printf("\n[CYCLE TERMINE] Passage en pause thermique (300s)...\n");
    }

    cleanup_platform();
    return 0;
}
