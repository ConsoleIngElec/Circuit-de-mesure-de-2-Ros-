#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

const char *stress_label[4] = {
    "DC:  0",
    "DC:  1",
    "100 Hz",
    "100 MHz"
};

// Un fichier par mode
char *mode_files[6] = {
    "MODE1.CSV",
    "MODE2.CSV",
    "MODE3.CSV",
    "MODE4.CSV",
    "MODE5.CSV",
    "MODE6.CSV"
};

// En-tetes des colonnes RO pour chaque mode
char *mode_headers[6] = {
    "Cycle;Temps;Temps_Sec;RO1_DC0_MHz;RO2_DC1_MHz;RO3_100Hz_MHz;RO4_100MHz_MHz\n",
    "Cycle;Temps;Temps_Sec;RO5_DC0_MHz;RO6_DC1_MHz;RO7_100Hz_MHz;RO8_100MHz_MHz\n",
    "Cycle;Temps;Temps_Sec;RO9_DC0_MHz;RO10_DC1_MHz;RO11_100Hz_MHz;RO12_100MHz_MHz\n",
    "Cycle;Temps;Temps_Sec;RO13_DC0_MHz;RO14_DC1_MHz;RO15_100Hz_MHz;RO16_100MHz_MHz\n",
    "Cycle;Temps;Temps_Sec;RO17_DC0_MHz;RO18_DC1_MHz;RO19_100Hz_MHz;RO20_100MHz_MHz\n",
    "Cycle;Temps;Temps_Sec;RO21_DC0_MHz;RO22_DC1_MHz;RO23_100Hz_MHz;RO24_100MHz_MHz\n"
};

char *mode_titles[6] = {
    "MODE 1 - RO_B 1 (DC0/DC1/100Hz/100MHz)\n",
    "MODE 2 - RO_B 2 (DC0/DC1/100Hz/100MHz)\n",
    "MODE 3 - RO_B 3 (DC0/DC1/100Hz/100MHz)\n",
    "MODE 4 - RO_LP 1 (DC0/DC1/100Hz/100MHz)\n",
    "MODE 5 - RO_LP 2 (DC0/DC1/100Hz/100MHz)\n",
    "MODE 6 - RO_LP 3 (DC0/DC1/100Hz/100MHz)\n"
};

static FATFS fatfs;

volatile int sd_ready     = 0;
static   int sd_was_ready = 0;

int remount_sd() {
    FRESULT res;
    f_mount(NULL, "0:/", 0);
    usleep(200000);
    res = f_mount(&fatfs, "0:/", 1);
    return (res == FR_OK);
}

void check_sd_card() {
    if (!sd_ready) {
        if (remount_sd()) {
            sd_ready = 1;
            if (!sd_was_ready) {
                printf("\n[SD] *** CARTE INSEREE *** Enregistrement repris.\n\r");
            }
        }
    }
    sd_was_ready = sd_ready;
}

void write_to_sd(char *filename, char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    if (!sd_ready) {
        printf("[SD] Donnee non enregistree (carte absente).\n\r");
        return;
    }

    res = f_open(&fil, filename, FA_WRITE | FA_OPEN_APPEND);
    if (res != FR_OK) {
        if (sd_ready) {
            sd_ready = 0;
            printf("\n[SD] *** CARTE RETIREE *** Donnees perdues !\n\r");
        }
        return;
    }

    res = f_write(&fil, data, strlen(data), &bw);
    if (res != FR_OK || bw != strlen(data)) {
        printf("[SD] ALERTE : Ecriture incomplete !\n\r");
        sd_ready = 0;
    }

    f_close(&fil);
}

void format_time(double total_seconds, char* out_str) {
    int days = (int)total_seconds / 86400;
    int rest = (int)total_seconds % 86400;
    int h    = rest / 3600;
    int m    = (rest % 3600) / 60;
    int s    = rest % 60;

    if (days > 0)
        sprintf(out_str, "%02dj:%02dh:%02dmin:%02ds", days, h, m, s);
    else
        sprintf(out_str, "%02dh:%02dmin:%02ds", h, m, s);
}

// Cree les 6 fichiers avec leur titre et en-tete si ils n'existent pas
void write_headers() {
    FILINFO fno;
    int k;
    for (k = 0; k < 6; k++) {
        if (f_stat(mode_files[k], &fno) != FR_OK) {
            write_to_sd(mode_files[k], mode_titles[k]);
            write_to_sd(mode_files[k], mode_headers[k]);
        }
    }
}

int main() {
    init_platform();

    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[256], time_str[40], mode_label[20];
    XTime tStart, tNow;

    float freq_all[24];

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs    *\n");
    printf("* Societe   : Universite de Bordeaux                 *\n");
    printf("* Ingenieur : Console MBOUBA                         *\n");
    printf("******************************************************\n");

    printf("[SD] Initialisation... ");
    if (remount_sd()) {
        sd_ready     = 1;
        sd_was_ready = 1;
        printf("[OK]\n\r");
        write_headers();
    } else {
        printf("[ERREUR] Carte SD absente. Mode console uniquement.\n\r");
    }

    XTime_GetTime(&tStart);

    while(1) {

        check_sd_card();

        printf("\n\n>>> DEBUT DU CYCLE N %06d", cycle_count);
        printf(" | SD : %s\n", sd_ready ? "[OK]" : "[ABSENTE]");

        for (int i = 0; i < 24; i++) freq_all[i] = 0.0f;

        for (k = 0; k < 6; k++) {

            check_sd_card();

            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;
            format_time(elapsed, time_str);

            if (k < 3) sprintf(mode_label, "RO_B %d",  k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE %06d | %s | Mode %d: %s | SD:%s\n",
                   cycle_count, time_str, k + 1, mode_label,
                   sd_ready ? "OK" : "ABSENTE");
            printf("  --------------------------------------------------\n");

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {

                check_sd_card();

                frequency_32bit = 0;

                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));

                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                float freq_mhz     = (float)frequency_32bit / 1000000.0f;
                int   global_ro_id = (k * 4) + ro_idx + 1;

                freq_all[global_ro_id - 1] = freq_mhz;

                if (frequency_32bit >= 1000000000) {
                    printf("    RO %-2d (%s) : %.3f GHz\n",
                           global_ro_id, stress_label[ro_idx],
                           freq_mhz / 1000.0f);
                } else {
                    printf("    RO %-2d (%s) : %.3f MHz\n",
                           global_ro_id, stress_label[ro_idx],
                           freq_mhz);
                }
            }

            // Ecriture dans le fichier du mode correspondant (k=0 -> MODE1.CSV etc.)
            int base = k * 4;
            sprintf(buffer, "%d;%s;%.0f;%.3f;%.3f;%.3f;%.3f\n",
                    cycle_count, time_str, elapsed,
                    freq_all[base],
                    freq_all[base + 1],
                    freq_all[base + 2],
                    freq_all[base + 3]);
            write_to_sd(mode_files[k], buffer);

            printf("\n");

            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        printf(">>> Fin du cycle %06d. En attente de la pause thermique (300s)...\n",
               cycle_count);

        for (int wait = 0; wait < 60; wait++) {
            usleep(5000000);
            check_sd_card();
        }

        cycle_count++;
    }

    cleanup_platform();
    return 0;
}
