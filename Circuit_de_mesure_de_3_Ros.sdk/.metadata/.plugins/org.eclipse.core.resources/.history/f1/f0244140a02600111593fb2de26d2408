#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

const char *stress_label[4] = {
    "DC:  0",
    "DC:  1",
    "100 Hz",
    "100 MHz"
};

static FATFS fatfs;
char *log_file_detail = "DATA_RO.CSV";
char *log_file_excel  = "DATA_XLS.CSV";

volatile int sd_ready     = 0;
static   int sd_was_ready = 0;

int remount_sd() {
    FRESULT res;
    f_mount(NULL, "0:/", 0);
    usleep(200000);
    res = f_mount(&fatfs, "0:/", 1);
    return (res == FR_OK);
}

void check_sd_card() {
    if (!sd_ready) {
        if (remount_sd()) {
            sd_ready = 1;
            if (!sd_was_ready) {
                printf("\n[SD] *** CARTE INSEREE *** Enregistrement repris.\n\r");
            }
        }
    }
    sd_was_ready = sd_ready;
}

void write_to_sd(char *filename, char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    if (!sd_ready) {
        printf("[SD] Donnee non enregistree (carte absente).\n\r");
        return;
    }

    res = f_open(&fil, filename, FA_WRITE | FA_OPEN_APPEND);
    if (res != FR_OK) {
        if (sd_ready) {
            sd_ready = 0;
            printf("\n[SD] *** CARTE RETIREE *** Donnees perdues !\n\r");
        }
        return;
    }

    res = f_write(&fil, data, strlen(data), &bw);
    if (res != FR_OK || bw != strlen(data)) {
        printf("[SD] ALERTE : Ecriture incomplete !\n\r");
        sd_ready = 0;
    }

    f_close(&fil);
}

void write_line_excel(float *freq, int cycle,
                      double elapsed, char *time_str) {
    FIL fil;
    UINT bw;
    FRESULT res;
    char part[256];

    if (!sd_ready) {
        printf("[SD] Ligne Excel non enregistree (carte absente).\n\r");
        return;
    }

    res = f_open(&fil, log_file_excel, FA_WRITE | FA_OPEN_APPEND);
    if (res != FR_OK) {
        if (sd_ready) {
            sd_ready = 0;
            printf("\n[SD] *** CARTE RETIREE *** Donnees perdues !\n\r");
        }
        return;
    }

    sprintf(part,
            "%d;%.0f;%s;"
            "%.3f;%.3f;%.3f;%.3f;"
            "%.3f;%.3f;%.3f;%.3f;"
            "%.3f;%.3f;%.3f;%.3f;",
            cycle, elapsed, time_str,
            freq[0],  freq[1],  freq[2],  freq[3],
            freq[4],  freq[5],  freq[6],  freq[7],
            freq[8],  freq[9],  freq[10], freq[11]);
    res = f_write(&fil, part, strlen(part), &bw);
    if (res != FR_OK || bw != strlen(part)) {
        printf("[SD] ALERTE : Ecriture Excel incomplete !\n\r");
        sd_ready = 0;
        f_close(&fil);
        return;
    }

    sprintf(part,
            "%.3f;%.3f;%.3f;%.3f;"
            "%.3f;%.3f;%.3f;%.3f;"
            "%.3f;%.3f;%.3f;%.3f\n",
            freq[12], freq[13], freq[14], freq[15],
            freq[16], freq[17], freq[18], freq[19],
            freq[20], freq[21], freq[22], freq[23]);
    res = f_write(&fil, part, strlen(part), &bw);
    if (res != FR_OK || bw != strlen(part)) {
        printf("[SD] ALERTE : Ecriture Excel incomplete !\n\r");
        sd_ready = 0;
    }

    f_close(&fil);
}

void format_time(double total_seconds, char* out_str) {
    int days = (int)total_seconds / 86400;
    int rest = (int)total_seconds % 86400;
    int h    = rest / 3600;
    int m    = (rest % 3600) / 60;
    int s    = rest % 60;

    if (days > 0)
        sprintf(out_str, "%02dj:%02dh:%02dmin:%02ds", days, h, m, s);
    else
        sprintf(out_str, "%02dh:%02dmin:%02ds", h, m, s);
}

void write_headers() {
    FILINFO fno;
    if (f_stat(log_file_detail, &fno) != FR_OK) {
        write_to_sd(log_file_detail,
            "Cycle;Temps_Texte;Temps_Sec;Mode;Label;Stress;RO_ID;Freq_MHz\n");
    }
    if (f_stat(log_file_excel, &fno) != FR_OK) {
        write_to_sd(log_file_excel,
            "Cycle;Temps_Sec;Temps_Texte;"
            "RO1_DC0;RO2_DC1;RO3_100Hz;RO4_100MHz;"
            "RO5_DC0;RO6_DC1;RO7_100Hz;RO8_100MHz;"
            "RO9_DC0;RO10_DC1;RO11_100Hz;RO12_100MHz;"
            "RO13_DC0;RO14_DC1;RO15_100Hz;RO16_100MHz;"
            "RO17_DC0;RO18_DC1;RO19_100Hz;RO20_100MHz;"
            "RO21_DC0;RO22_DC1;RO23_100Hz;RO24_100MHz\n");
    }
}

int main() {
    init_platform();

    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[256], time_str[40], mode_label[20];
    XTime tStart, tNow;

    float  freq_all[24];
    double elapsed_capture = 0;

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs    *\n");
    printf("* Societe   : Universite de Bordeaux                 *\n");
    printf("* Ingenieur : Console MBOUBA                         *\n");
    printf("******************************************************\n");

    printf("[SD] Initialisation... ");
    if (remount_sd()) {
        sd_ready     = 1;
        sd_was_ready = 1;
        printf("[OK]\n\r");
        write_headers();
    } else {
        printf("[ERREUR] Carte SD absente. Mode console uniquement.\n\r");
    }

    XTime_GetTime(&tStart);

    while(1) {

        check_sd_card();

        printf("\n\n>>> DEBUT DU CYCLE N %06d", cycle_count);
        printf(" | SD : %s\n", sd_ready ? "[OK]" : "[ABSENTE]");

        for (int i = 0; i < 24; i++) freq_all[i] = 0.0f;

        for (k = 0; k < 6; k++) {

            check_sd_card();

            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;
            format_time(elapsed, time_str);

            if (k == 0) elapsed_capture = elapsed;

            if (k < 3) sprintf(mode_label, "RO_B %d",  k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE %06d | %s | Mode %d: %s | SD:%s\n",
                   cycle_count, time_str, k + 1, mode_label,
                   sd_ready ? "OK" : "ABSENTE");
            printf("  --------------------------------------------------\n");

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {

                check_sd_card();

                frequency_32bit = 0;

                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));

                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                float freq_mhz     = (float)frequency_32bit / 1000000.0f;
                int   global_ro_id = (k * 4) + ro_idx + 1;

                freq_all[global_ro_id - 1] = freq_mhz;

                if (frequency_32bit >= 1000000000) {
                    printf("    RO %-2d (%s) : %.3f GHz\n",
                           global_ro_id, stress_label[ro_idx],
                           freq_mhz / 1000.0f);
                } else {
                    printf("    RO %-2d (%s) : %.3f MHz\n",
                           global_ro_id, stress_label[ro_idx],
                           freq_mhz);
                }

                sprintf(buffer, "%d;%s;%.0f;Mode %d;%s;%s;RO %d;%.3f\n",
                        cycle_count, time_str, elapsed,
                        k + 1, mode_label,
                        stress_label[ro_idx],
                        global_ro_id, freq_mhz);
                write_to_sd(log_file_detail, buffer);
            }

            printf("\n");

            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        char time_str_capture[40];
        format_time(elapsed_capture, time_str_capture);
        write_line_excel(freq_all, cycle_count,
                         elapsed_capture, time_str_capture);

        printf(">>> Fin du cycle %06d. En attente de la pause thermique (300s)...\n",
               cycle_count);

        for (int wait = 0; wait < 60; wait++) {
            usleep(5000000);
            check_sd_card();
        }

        cycle_count++;
    }

    cleanup_platform();
    return 0;
}
