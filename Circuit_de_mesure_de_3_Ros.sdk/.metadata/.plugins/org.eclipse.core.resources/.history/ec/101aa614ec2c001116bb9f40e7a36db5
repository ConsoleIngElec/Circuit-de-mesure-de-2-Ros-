/*This file implements functions to control the PMIC IRPS5401 mounted on the Avnet Ultra96-V2
 board to power the XCZU3EG FPGA. Communication uses the I2C/PMBus protocol.

The PMIC contains 6144 registers, addresses 0 to 6143, divided into 24 pages (00h to 17h).
Each page has 256 registers. The page number register is located at address FFh.

Example : to write or read register at address 515 :
    Page number      = 515 / 256 = 2
    Register address = 515 mod 256 = 3
      1. Write 2 to register FFh  (select page)
      2. Write or read data at register 3

Page organization :
    Page 0–3   : COMMON REG MAP SECTIONS
    Page 4–5   : LOOP A REG MAP SECTIONS
    Page 6–7   : PMBUS LOOP A REG MAP SECTIONS
    Page 8–9   : LOOP B REG MAP SECTIONS
    Page A–B   : PMBUS LOOP B REG MAP SECTIONS
    Page C–D   : LOOP C REG MAP SECTIONS
    Page E–F   : PMBUS LOOP C REG MAP SECTIONS
    Page 10–11 : LOOP D REG MAP SECTIONS
    Page 12–13 : PMBUS LOOP D REG MAP SECTIONS
    Page 14–15 : LDO REG MAP SECTIONS
    Page 16–17 : PMBUS REG MAP SECTIONS

***************************************************************************************************/


#include <stdio.h>
#include "xparameters.h"
#include "sleep.h"
#include "xiicps.h"
#include "xil_printf.h"
#include "pmic.h"

/*
 * DeviceId is defined in xparameters.h.
 * Use XPAR_PSU_I2C_1_DEVICE_ID to communicate with the PMIC.
 * This I2C bus is connected to MIO 4 and MIO 5 on the PS.
 * IIC MUX address : 0x75 — PMIC channel : 0x10
 */
#define DeviceId        XPAR_PSU_I2C_1_DEVICE_ID
#define IIC_SCLK_RATE   100000

/*
 * PMBus register addresses (IRPS5401 datasheet, section 12)
 * Used in all functions below.
 */
#define REG_VOUT_MODE       0x20    /* sets exponent format for VOUT commands          */
#define REG_VOUT_COMMAND    0x21    /* sets target output voltage                      */
#define REG_VOUT_MAX        0x24    /* upper limit on commanded output voltage         */

/*
 * VOUT_MODE values for supported exponents (Linear format)
 * Encoding : bits[7:5] = 000 (Linear mode), bits[4:0] = exponent in 2's complement
 *   -8  : 0b11000 → 0x18 → step = 1/256  ≈ 3.906 mV  (default after power-on)
 *   -9  : 0b11001 → 0x19 → step = 1/512  ≈ 1.953 mV
 */
#define VOUT_MODE_EXP_N8    0x18
#define VOUT_MODE_EXP_N9    0x19

/* Helper : initialize IIC peripheral (avoids duplication in every function) */
static void IIC_Init(XIicPs *IicInstance)
{
    XIicPs_Config *ConfigPtr;
    ConfigPtr = XIicPs_LookupConfig(DeviceId);
    XIicPs_CfgInitialize(IicInstance, ConfigPtr, ConfigPtr->BaseAddress);
    XIicPs_SetSClk(IicInstance, IIC_SCLK_RATE);
}

/* -------------------------------------------------------------------------
 * set_channel_IIC_MUX
 * Select channel in IIC MUX (8 channels). PMIC channel is channel 5 (0x10).
 * ------------------------------------------------------------------------- */
void set_channel_IIC_MUX(int IIC_MUX_Addr, u8 Channel)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    XIicPs_MasterSendPolled(&IicInstance, &Channel, 1, IIC_MUX_Addr);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(250000);
}

/* -------------------------------------------------------------------------
 * set_PMIC_page
 * Select PMBus page in PMIC. 24 pages available.
 * Choose LOOP A, B, C or D PMBus page before accessing loop registers.
 * ------------------------------------------------------------------------- */
void set_PMIC_page(int Loop)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8 Page[2];
    u8 AdressPMIC = 0x13;

    Page[0] = 0xFF;  /* page register address */
    switch(Loop)
    {
        case 0xA :  Page[1] = 0x6;  break;
        case 0xA1:  Page[1] = 0x7;  break;
        case 0xB :  Page[1] = 0xA;  break;
        case 0xB1:  Page[1] = 0xB;  break;
        case 0xC :  Page[1] = 0xE;  break;
        case 0xC1:  Page[1] = 0xF;  break;
        case 0xD :  Page[1] = 0x12; break;
        case 0xD1:  Page[1] = 0x13; break;
        case 0xD0:  Page[1] = 0x14; break;
        default  :  return;
    }

    XIicPs_MasterSendPolled(&IicInstance, Page, 2, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(250000);
}

/* -------------------------------------------------------------------------
 * set_Vmax
 * Set VOUT_MAX (register 0x24) to an upper voltage limit.
 * VOUT_MAX must always be >= VOUT_COMMAND, otherwise the PMIC clamps Vout.
 * Reads current VOUT_MODE first to compute the correct raw command value.
 * ------------------------------------------------------------------------- */
void set_Vmax(float Vmax)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8  AdressPMIC = 0x13;
    u8  V_mode_reg = REG_VOUT_MODE;  /* CORRECTION : 0x40 → 0x20 */
    u8  Buffer[2];
    u8  Write[3];
    u16 command;

    /* Read VOUT_MODE to determine current resolution */
    XIicPs_MasterSendPolled(&IicInstance, &V_mode_reg, 1, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(10000);

    XIicPs_MasterRecvPolled(&IicInstance, Buffer, 2, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));

    /* Compute raw command according to current exponent */
    switch(Buffer[0])
    {
        case VOUT_MODE_EXP_N8: command = (u16)(Vmax * 256); break;  /* exponent -8 */
        case VOUT_MODE_EXP_N9: command = (u16)(Vmax * 512); break;  /* exponent -9  CORRECTION : 0x17 → 0x19 */
        default              : return;
    }

    /* Write VOUT_MAX — CORRECTION : 0x48 → 0x24 */
    Write[0] = REG_VOUT_MAX;
    Write[1] = (u8)(command & 0xFF);
    Write[2] = (u8)(command >> 8);

    XIicPs_MasterSendPolled(&IicInstance, Write, 3, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(250000);
}

/* -------------------------------------------------------------------------
 * set_resolution
 * Change VOUT_MODE exponent and update VOUT_COMMAND immediately after.
 *
 * Resolution 1 : exponent -8 → step 1/256 ≈ 3.906 mV  (default after power-on)
 * Resolution 2 : exponent -9 → step 1/512 ≈ 1.953 mV
 *
 * CRITICAL : the new VOUT_COMMAND value is computed BEFORE writing VOUT_MODE.
 * Then both registers are written back-to-back with NO delay between them.
 * Reason : with a 250ms delay between the two writes (as in the original code),
 * the PMIC interprets the old raw command with the new exponent during 250ms,
 * which halves the output voltage (ex: 0.85V → 0.425V) and triggers UVP → board cuts off.
 * The ~100us I2C back-to-back window is safe — UVP cannot trigger that fast.
 * ------------------------------------------------------------------------- */
void set_resolution(int Resolution)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8  Write[3];
    u16 command;
    u8  AdressPMIC        = 0x13;
    u8  new_mode;
    u16 resolution_factor;

    /* Step 1 : determine new VOUT_MODE byte and resolution factor */
    switch(Resolution)
    {
        case 1:
            new_mode          = VOUT_MODE_EXP_N8;  /* exponent -8, step ≈ 3.906 mV */
            resolution_factor = 256;
            break;
        case 2:
            new_mode          = VOUT_MODE_EXP_N9;  /* exponent -9, step ≈ 1.953 mV — CORRECTION : 0x17 → 0x19 */
            resolution_factor = 512;
            break;
        default:
            return;
    }

    /* Step 2 : pre-compute VOUT_COMMAND for 0.85V at the new resolution.
     * Must be done BEFORE writing VOUT_MODE so the value is ready to send immediately. */
    command = (u16)(0.85f * resolution_factor);

    /* Step 3 : write VOUT_MODE — CORRECTION : 0x40 → 0x20 */
    Write[0] = REG_VOUT_MODE;
    Write[1] = new_mode;
    Write[2] = 0x00;
    XIicPs_MasterSendPolled(&IicInstance, Write, 3, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    /* NO usleep here — write VOUT_COMMAND immediately to avoid transient wrong voltage */

    /* Step 4 : write VOUT_COMMAND immediately after VOUT_MODE
     * CORRECTION : 0x42 → 0x21
     * CORRECTION : usleep(250000) removed between the two writes — it was causing
     *              250ms at half voltage → UVP triggered → board cut off */
    Write[0] = REG_VOUT_COMMAND;
    Write[1] = (u8)(command & 0xFF);
    Write[2] = (u8)(command >> 8);
    XIicPs_MasterSendPolled(&IicInstance, Write, 3, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(250000);  /* delay is safe here — VOUT_COMMAND is already applied */
}

/* -------------------------------------------------------------------------
 * set_voltage
 * Set VOUT_COMMAND (register 0x21) to the requested voltage in Volts.
 * Reads VOUT_MODE first to adapt the raw command to the current resolution.
 * Supported resolutions : exponent -8 (0x18) and exponent -9 (0x19).
 * ------------------------------------------------------------------------- */
void set_voltage(float Voltage)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8  Write[3];
    u8  Buffer[2];
    u16 command;
    u8  AdressPMIC = 0x13;
    u8  V_mode_reg = REG_VOUT_MODE;  /* CORRECTION : 0x40 → 0x20 */

    /* Read current VOUT_MODE to determine resolution */
    XIicPs_MasterSendPolled(&IicInstance, &V_mode_reg, 1, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));

    XIicPs_MasterRecvPolled(&IicInstance, Buffer, 2, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));

    /* Compute raw command according to current exponent */
    switch(Buffer[0])
    {
        case VOUT_MODE_EXP_N8: command = (u16)(Voltage * 256); break;  /* exponent -8 */
        case VOUT_MODE_EXP_N9: command = (u16)(Voltage * 512); break;  /* exponent -9  CORRECTION : 0x17 → 0x19 */
        default              : return;  /* unknown mode — do nothing */
    }

    /* Write VOUT_COMMAND — CORRECTION : 0x42 → 0x21 */
    Write[0] = REG_VOUT_COMMAND;
    Write[1] = (u8)(command & 0xFF);
    Write[2] = (u8)(command >> 8);

    XIicPs_MasterSendPolled(&IicInstance, Write, 3, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
}

/* -------------------------------------------------------------------------
 * read_register
 * Read a 16-bit PMBus register value (Little-endian : LSB first).
 * Call set_PMIC_page() first to select the correct page.
 * ------------------------------------------------------------------------- */
u16 read_register(int reg)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8  Buffer[2];
    u8  AdressPMIC = 0x13;
    u8  reg_PMIC   = (u8)reg;
    u16 value;

    XIicPs_MasterSendPolled(&IicInstance, &reg_PMIC, 1, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));

    XIicPs_MasterRecvPolled(&IicInstance, Buffer, 2, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));

    /* Little-endian : Buffer[0] = LSB, Buffer[1] = MSB */
    value = ((u16)(Buffer[1]) << 8) + Buffer[0];
    return value;
}

/* -------------------------------------------------------------------------
 * write_register
 * Write a 16-bit value to a PMBus register (Little-endian : LSB first).
 * Call set_PMIC_page() first to select the correct page.
 * ------------------------------------------------------------------------- */
void write_register(int reg, u16 command)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8 Write[3];
    u8 AdressPMIC = 0x13;

    Write[0] = (u8)reg;
    Write[1] = (u8)(command & 0xFF);  /* LSB */
    Write[2] = (u8)(command >> 8);    /* MSB */

    XIicPs_MasterSendPolled(&IicInstance, Write, 3, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(250000);
}

/* -------------------------------------------------------------------------
 * READ_SMBALERT_MASK
 * Read SMBALERT mask register for a given status register code.
 * Returns the 16-bit mask value.
 * ------------------------------------------------------------------------- */
u16 READ_SMBALERT_MASK(int status)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8  Buffer[2];
    u8  Write[3];
    u16 value;
    u8  AdressPMIC = 0x13;
    u16 command;

    command  = ((0x1) << 8) + status;
    Write[0] = 0x36;
    Write[1] = (u8)(command >> 8);
    Write[2] = (u8)(command & 0xFF);

    xil_printf("READ: %x,%x\n", Write[1], Write[2]);

    XIicPs_MasterSendPolled(&IicInstance, Write, 3, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(250000);

    XIicPs_MasterRecvPolled(&IicInstance, Buffer, 2, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));

    value = ((u16)(Buffer[0]) << 8) + Buffer[1];
    return value;
}

/* -------------------------------------------------------------------------
 * WRITE_SMBALERT_MASK
 * Write SMBALERT mask register for a given status register code and mask value.
 * ------------------------------------------------------------------------- */
void WRITE_SMBALERT_MASK(int status, int mask)
{
    XIicPs IicInstance;
    IIC_Init(&IicInstance);

    u8  Write[3];
    u8  AdressPMIC = 0x13;
    u16 command;

    command  = (status << 8) + mask;
    Write[0] = 0x36;
    Write[1] = (u8)(command >> 8);
    Write[2] = (u8)(command & 0xFF);

    xil_printf("WRITE : %x %x\n", Write[1], Write[2]);

    XIicPs_MasterSendPolled(&IicInstance, Write, 3, AdressPMIC);
    while (XIicPs_BusIsBusy(&IicInstance));
    usleep(250000);
}
