#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

// ============================================================
//   GESTION SD Ś VARIABLES GLOBALES
// ============================================================
static FATFS fatfs;
char *log_file = "DATA_RO.CSV";

volatile int sd_ready    = 0;  // volatile obligatoire (modifiķ dans write_to_sd)
static   int sd_was_ready = 0; // Pour dķtecter les transitions insertion/retrait

// ============================================================
//   REMONTAGE COMPLET SD
// ============================================================
int remount_sd() {
    FRESULT res;
    f_mount(NULL, "0:/", 0);   // Unmount lazy Ś ne bloque pas si carte absente
    usleep(200000);            // 200 ms stabilisation mķcanique
    res = f_mount(&fatfs, "0:/", 1);
    return (res == FR_OK);
}

// ============================================================
//   SURVEILLANCE SD Ś dķtecte insertion ET retrait
// ============================================================
void check_sd_card() {
    if (!sd_ready) {
        // Tentative de remontage (carte vient d'Ļtre insķrķe ?)
        if (remount_sd()) {
            sd_ready = 1;
            if (!sd_was_ready) {
                printf("\n[SD] *** CARTE INSEREE *** Enregistrement repris.\n\r");
            }
        }
    }
    sd_was_ready = sd_ready;
}

// ============================================================
//   ECRITURE SD SECURISEE
//   - Signale le retrait sur le terminal
//   - Signale la perte de donnķes si carte absente
// ============================================================
void write_to_sd(char *filename, char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    if (!sd_ready) {
        printf("[SD] Donnee non enregistree (carte absente).\n\r");
        return;
    }

    res = f_open(&fil, filename, FA_WRITE | FA_OPEN_APPEND);
    if (res != FR_OK) {
        if (sd_ready) {
            sd_ready = 0;
            printf("\n[SD] *** CARTE RETIREE *** Donnees perdues !\n\r");
        }
        return;
    }

    res = f_write(&fil, data, strlen(data), &bw);
    if (res != FR_OK || bw != strlen(data)) {
        printf("[SD] ALERTE : Ecriture incomplete !\n\r");
        sd_ready = 0;
    }

    f_close(&fil);
}

// ============================================================
//   FORMATAGE DU TEMPS (Console)
// ============================================================
void format_time(double total_seconds, char* out_str) {
    int days = (int)total_seconds / 86400;
    int rest = (int)total_seconds % 86400;
    int h    = rest / 3600;
    int m    = (rest % 3600) / 60;
    int s    = rest % 60;

    if (days > 0)
        sprintf(out_str, "%02dj:%02dh:%02dmin:%02ds", days, h, m, s);
    else
        sprintf(out_str, "%02dh:%02dmin:%02ds", h, m, s);
}

// ============================================================
//   MAIN
// ============================================================
int main() {
    init_platform();

    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[512], time_str[40], mode_label[20];
    XTime tStart, tNow;

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs    *\n");
    printf("* Societe   : Universite de Bordeaux                 *\n");
    printf("* Ingenieur : Console MBOUBA                         *\n");
    printf("******************************************************\n");

    // --- Initialisation SD au dķmarrage ---
    printf("[SD] Initialisation... ");
    if (remount_sd()) {
        sd_ready     = 1;
        sd_was_ready = 1;
        printf("[OK]\n\r");

        // En-tĻte CSV uniquement si le fichier n'existe pas dķjÓ
        // (reprise propre aprĶs coupure sans doublon d'en-tĻte)
        FILINFO fno;
        if (f_stat(log_file, &fno) != FR_OK) {
            write_to_sd(log_file,
                "Cycle;Temps_Texte;Temps_Sec;Mode;Label;RO_Global_ID;Freq_MHz\n");
        }
    } else {
        printf("[ERREUR] Carte SD absente. Mode console uniquement.\n\r");
    }

    XTime_GetTime(&tStart);

    while(1) {

        // --- Surveillance SD en tĻte de chaque cycle ---
        check_sd_card();

        printf("\n\n>>> DEBUT DU CYCLE N %06d", cycle_count);
        printf(" | SD : %s\n", sd_ready ? "[OK]" : "[ABSENTE]");

        for (k = 0; k < 6; k++) {
            // Attente du signal ALLOW (Seconde 25 du FPGA)
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;
            format_time(elapsed, time_str);

            // Label gķnķral du mode
            if (k < 3) sprintf(mode_label, "RO_B %d", k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE %06d | %s | Mode %d: %s | SD:%s\n",
                   cycle_count, time_str, k + 1, mode_label,
                   sd_ready ? "OK" : "ABSENTE");
            printf("  --------------------------------------------------\n");

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;

                // Reconstitution 32-bits (4 octets) Ś NON MODIFI╔
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));

                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                float freq_mhz = (float)frequency_32bit / 1000000.0;
                int global_ro_id = (k * 4) + ro_idx + 1;

                // Affichage Console Ś NON MODIFI╔
                if (frequency_32bit >= 1000000000) {
                    printf("    RO %d : %.3f GHz\n", global_ro_id, freq_mhz / 1000.0);
                } else {
                    printf("    RO %d : %.3f MHz\n", global_ro_id, freq_mhz);
                }

                // Enregistrement SD Ś NON MODIFI╔ (format d'origine prķservķ)
                sprintf(buffer, "%d;%s;%.0f;Mode %d;%s;RO %d;%.3f\n",
                        cycle_count, time_str, elapsed,
                        k + 1, mode_label, global_ro_id, freq_mhz);
                write_to_sd(log_file, buffer);
            }

            printf("\n");

            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        printf(">>> Fin du cycle %06d. En attente de la pause thermique (300s)...\n",
               cycle_count);
        cycle_count++;
    }

    cleanup_platform();
    return 0;
}
