#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"    // Pour le chronomŤtre haute prťcision
#include "sleep.h"

// --- ADRESSES IP (Vťrifie bien dans ton Address Editor Vivado) ---
#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0   // Octet de donnťe
#define REG_ALLOW_OFFSET   4   // Signal Allow
#define REG_DONE_OFFSET    8   // Signal Done

static FATFS fatfs;
char *log_file = "DATA_RO.CSV";

void write_to_sd(char *filename, char *data) {
    FIL fil;
    UINT bw;
    if (f_open(&fil, filename, FA_WRITE | FA_OPEN_APPEND) == FR_OK) {
        f_write(&fil, data, strlen(data), &bw);
        f_close(&fil);
    }
}

int main() {
    init_platform();

    u32 byte_read, allow_signal, frequency_32bit;
    int k, ro_idx, b;
    int capture_count = 1;
    char buffer[256];

    XTime tStart, tNow;
    XTime_GetTime(&tStart); // Point de dťpart T=0

    // Montage SD et EntÍte
    if (f_mount(&fatfs, "0:/", 1) == FR_OK) {
        write_to_sd(log_file, "Capture;Horodatage;Mode;RO_ID;Freq_MHz\n");
    }

    while(1) {
        // Parcours des 6 modes gťrťs par ton Gen_mode.vhd
        for (k = 0; k < 6; k++) {

            // 1. Attente passive du signal ALLOW (le FPGA est ŗ la seconde 25)
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            // 2. Calcul du temps HH:MM:SS via xtime_l
            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;
            int h = (int)elapsed / 3600;
            int m = ((int)elapsed % 3600) / 60;
            int s = (int)elapsed % 60;

            printf("\n>>> CAPTURE N %03d  |  TEMPS : %02dh:%02dmin:%02ds\n", capture_count, h, m, s);
            printf("------------------------------------------------------\n");

            // 3. Lecture des 4 ROs du mode (Sťquencement 8-bits)
            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;

                // Reconstitution du mot de 32 bits ŗ partir de 4 octets
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));

                    // Envoi du signal DONE pour l'octet suivant
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++); // Petit dťlai de stabilitť
                }

                float mhz = (float)frequency_32bit / 1000000.0;
                int ro_global_id = (k * 4) + ro_idx;

                // Affichage Console
                printf("  RO %2d | Freq : %8.3f MHz\n", ro_global_id, mhz);

                // …criture SD au format CSV
                sprintf(buffer, "%d;%02dh%02dm%02ds;%d;%d;%.3f\n",
                        capture_count, h, m, s, k, ro_global_id, mhz);
                write_to_sd(log_file, buffer);
            }

            capture_count++;

            // 4. On attend que le FPGA rel‚che le signal ALLOW (fin du cycle de 50s)
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        // Ici, les 6 modes sont finis. Le FPGA est en PAUSE_THERMIQUE (300s).
        // Le code C va naturellement boucler et attendre le prochain ALLOW du Mode 0.
        printf("\n[SD] Fin de cycle. En attente de la pause thermique (300s)...\n");
    }

    cleanup_platform();
    return 0;
}
