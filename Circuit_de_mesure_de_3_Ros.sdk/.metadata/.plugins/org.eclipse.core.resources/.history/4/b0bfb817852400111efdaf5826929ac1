#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

// --- ADRESSES IP ---
#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

static FATFS fatfs;
char *log_file = "Veillissement_transistors.csv";
int sd_is_working = 0;

// --- FONCTION D'ECRITURE SECURISEE (NE BLOQUE PAS LE TERMINAL) ---
void write_to_sd(char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    // Tentative d'ouverture rapide
    res = f_open(&fil, log_file, FA_WRITE | FA_OPEN_APPEND);

    if (res == FR_OK) {
        if (sd_is_working == 0) {
            printf("\n  [INFO] Carte SD detectee ! Enregistrement active.\n");
            sd_is_working = 1;
        }
        f_write(&fil, data, strlen(data), &bw);
        f_sync(&fil); // Force l'ecriture physique pour eviter les fichiers vides
        f_close(&fil);
    } else {
        if (sd_is_working == 1) {
            printf("\n  [!!! ALERTE SD !!!] Carte retiree ou Erreur. Mode CONSOLE uniquement.\n");
            sd_is_working = 0;
            f_mount(NULL, "0:/", 0); // Demonter proprement pour eviter le gel du CPU
        }
    }
}

int main() {
    init_platform();

    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[512], time_str[40], mode_label[20];
    XTime tStart, tNow;

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs    *\n");
    printf("* Societe   : Universite de Bordeaux                 *\n");
    printf("* Ingenieur : Console MBOUBA                         *\n");
    printf("******************************************************\n");

    // 1. PAUSE DE SECURITE (Laisse le temps a la SD de s'allumer)
    printf("[SYS] Initialisation... Attente de la carte SD (2s)\n");
    sleep(2);

    // 2. MONTAGE INITIAL
    if (f_mount(&fatfs, "0:/", 1) == FR_OK) {
        sd_is_working = 1;
        printf("[SD CARD] OK : Carte prete.\n");
        // Ecriture de l'entete (si nouveau fichier)
        write_to_sd("Cycle;Temps_Texte;Temps_Sec;Mode;Label;RO_Global_ID;Freq_MHz\n");
    } else {
        printf("[SD CARD] ATTENTION : Carte absente. Lancement en mode console seule.\n");
        sd_is_working = 0;
    }

    XTime_GetTime(&tStart);

    while(1) {
        printf("\n\n>>> DEBUT DU CYCLE N %06d\n", cycle_count);

        for (k = 0; k < 6; k++) {

            // Si la carte a ete remise, on tente un remontage discret ici
            if (sd_is_working == 0) {
                f_mount(&fatfs, "0:/", 0);
            }

            // Attente du signal ALLOW du FPGA
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;

            // Formatage Temps JJ:HH:MM:SS
            int d = (int)elapsed / 86400;
            int h = ((int)elapsed % 86400) / 3600;
            int m = ((int)elapsed % 3600) / 60;
            int s = (int)elapsed % 60;
            sprintf(time_str, "%02dj:%02dh:%02dm:%02ds", d, h, m, s);

            if (k < 3) sprintf(mode_label, "RO_B %d", k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE %06d | %s | Mode %d: %s\n", cycle_count, time_str, k + 1, mode_label);
            printf("  --------------------------------------------------\n");

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;

                // Lecture du registre (4 octets)
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));

                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d_delay = 0; d_delay < 500; d_delay++);
                }

                float freq_mhz = (float)frequency_32bit / 1000000.0;
                int global_ro_id = (k * 4) + ro_idx + 1;

                // 1. Affichage Console (Priorite)
                if (frequency_32bit >= 1000000000) {
                    printf("    RO %d : %.3f GHz\n", global_ro_id, freq_mhz / 1000.0);
                } else {
                    printf("    RO %d : %.3f MHz\n", global_ro_id, freq_mhz);
                }

                // 2. Preparation des donnees pour Excel
                sprintf(buffer, "%d;%s;%.0f;Mode %d;%s;RO %d;%.3f\n",
                        cycle_count, time_str, elapsed, k + 1, mode_label, global_ro_id, freq_mhz);

                // 3. Ecriture SD (si presente)
                write_to_sd(buffer);
            }

            printf("\n"); // Espace entre les modes

            // Attente de la fin du signal ALLOW
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        printf(">>> Fin du cycle %06d. Attente pause thermique (300s).\n", cycle_count);
        printf(">>> [ASTUCE] C'est le meilleur moment pour retirer la carte SD si besoin.\n");
        cycle_count++;
    }

    cleanup_platform();
    return 0;
}
