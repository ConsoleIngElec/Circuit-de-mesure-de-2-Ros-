#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xtime_l.h"  // Pour mesurer le temps réel

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

int main() {
    init_platform();

    u32 byte_read, allow_signal, frequency_32bit;
    int k, ro_idx, b;

    // Variables pour le chronomètre
    XTime tStart, tEnd;
    double duration_seconds;

    printf("\n======================================================\n");
    printf("   LECTURE 24 ROs AVEC CHRONOMETRAGE DES MODES       \n");
    printf("======================================================\n");

    while(1) {
        for (k = 0; k < 6; k++) {
            printf("\n>>> [MODE %d] Attente du signal Allow (Seconde 25)...\n", k);

            // On démarre le chrono au moment où on commence à attendre
            XTime_GetTime(&tStart);

            // 1. Attente du signal Allow
            do {
                allow_signal = Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET);
            } while ((allow_signal & 0x01) == 0);

            // On arrête le chrono dès que Allow monte
            XTime_GetTime(&tEnd);

            // Calcul du temps écoulé (Fréquence CPU sur Zynq MPSoC est COUNTS_PER_SECOND)
            duration_seconds = (double)(tEnd - tStart) / COUNTS_PER_SECOND;

            printf("  [INFO] Temps d'attente reel : %.3f secondes\n", duration_seconds);
            printf("  [CAPTURED] Lecture des 4 ROs :\n");

            // 2. Lecture des 16 octets (4 ROs x 4 octets)
            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));

                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int delay = 0; delay < 500; delay++);
                }
                printf("    RO #%02d : %lu Hz\n", (k * 4) + ro_idx, frequency_32bit);
            }

            // 3. Attente de la fin du signal pour passer au mode suivant
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }
        printf("\n[CYCLE TERMINE] Entree en pause thermique (300s)...\n");
    }

    cleanup_platform();
    return 0;
}
