#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"      /* Pour la carte SD */
#include "ff.h"         /* Bibliothčque FatFs */
#include "xtime_l.h"    /* Chronomčtre haute précision */
#include "sleep.h"

// --- ADRESSES IP (Vérifie dans ton Address Editor Vivado) ---
#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

static FATFS fatfs;
char *log_file = "DATA_RO.CSV";

// --- FONCTION : FORMATAGE DU TEMPS (HH:MM:SS ou JJ:HH:MM:SS) ---
void format_time(double total_seconds, char* out_str) {
    int days = (int)total_seconds / 86400;
    int rest = (int)total_seconds % 86400;
    int h = rest / 3600;
    int m = (rest % 3600) / 60;
    int s = rest % 60;

    if (days > 0)
        sprintf(out_str, "%02dj:%02dh:%02dmin:%02ds", days, h, m, s);
    else
        sprintf(out_str, "%02dh:%02dmin:%02ds", h, m, s);
}

// --- FONCTION : ECRITURE SUR SD ---
void write_to_sd(char *filename, char *data) {
    FIL fil;
    UINT bw;
    if (f_open(&fil, filename, FA_WRITE | FA_OPEN_APPEND) == FR_OK) {
        f_write(&fil, data, strlen(data), &bw);
        f_close(&fil);
    }
}

int main() {
    init_platform();

    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[256], time_str[40], label[20];
    XTime tStart, tNow;

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs    *\n");
    printf("* Societe   : Universite de Bordeaux                 *\n");
    printf("* Ingenieur : Console MBOUBA                         *\n");
    printf("******************************************************\n");

    // 1. DETECTION DE LA CARTE SD
    printf("[SD CARD] Initialisation... ");
    if (f_mount(&fatfs, "0:/", 1) != FR_OK) {
        printf("ERREUR : Carte SD non detectee ou corrompue !\n");
    } else {
        printf("OK : Carte SD prete.\n");
        // Entęte CSV : On précise bien Frequence_MHz pour Excel
        write_to_sd(log_file, "Cycle;Temps;Mode;Label;RO_Inst;Frequence_MHz\n");
    }

    XTime_GetTime(&tStart); // Début du chronomčtre (T=0)

    while(1) {
        printf("\n>>> DEBUT DU CYCLE N %06d\n", cycle_count);

        // --- BOUCLE SUR LES 6 MODES ---
        for (k = 0; k < 6; k++) {

            // Attente du signal ALLOW du FPGA (Seconde 25)
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            // Capture du temps précis
            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;
            format_time(elapsed, time_str);

            // Détermination du Label du Mode (B1-B3 puis LP1-LP3)
            if (k < 3) sprintf(label, "RO_B %d", k + 1);
            else       sprintf(label, "RO_LP %d", k - 2);

            printf("  CAPTURE %06d | %s | Mode %d: %s\n", cycle_count, time_str, k + 1, label);
            printf("  --------------------------------------------------\n");

            // Lecture des 4 ROs du mode
            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;

                // Reconstitution 32-bits par 4 octets avec Handshake Done
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));

                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                // --- CALCULS DES UNITES ---
                float freq_mhz = (float)frequency_32bit / 1000000.0;

                // Affichage Console avec conversion GHz si > 1000
                if (frequency_32bit >= 1000000000) {
                    printf("    %s #%d : %.3f GHz\n", label, ro_idx + 1, freq_mhz / 1000.0);
                } else {
                    printf("    %s #%d : %.3f MHz\n", label, ro_idx + 1, freq_mhz);
                }

                // --- ENREGISTREMENT SD ---
                // Note : On enregistre freq_mhz (nombre seul) pour Excel
                sprintf(buffer, "%d;%s;Mode %d;%s;%d;%.3f\n",
                        cycle_count, time_str, k + 1, label, ro_idx + 1, freq_mhz);
                write_to_sd(log_file, buffer);
            }

            // Attente de la fin de la fenętre ALLOW du FPGA
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        printf("\n>>> Fin du cycle %06d. En attente de la pause thermique (300s)...\n", cycle_count);
        cycle_count++;
    }

    cleanup_platform();
    return 0;
}
