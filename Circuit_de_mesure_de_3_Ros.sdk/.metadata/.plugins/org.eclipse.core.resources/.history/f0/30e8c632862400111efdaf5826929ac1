#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

static FATFS fatfs;
char *log_file = "Veillissement_transistors.csv";
int sd_present = 0;

// --- FONCTION D'ECRITURE "NON-BLOQUANTE" ---
void try_write_sd(char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    // On tente d'ouvrir le fichier.
    // Si la carte n'est pas lŗ, cette fonction DOIT ťchouer rapidement.
    res = f_open(&fil, log_file, FA_WRITE | FA_OPEN_APPEND);

    if (res == FR_OK) {
        f_write(&fil, data, strlen(data), &bw);
        f_sync(&fil); // On force l'ťcriture physique immťdiatement
        f_close(&fil);
        sd_present = 1;
    } else {
        // Si erreur (carte retirťe), on dťsactive la SD pour ce tour
        if (sd_present == 1) {
            printf("\n  [!] ERREUR CRITIQUE SD : Retrait detecte. Mode console pure active.\n");
        }
        sd_present = 0;
        f_mount(NULL, "0:/", 0); // On libŤre le bus pour ťviter de figer la console
    }
}

int main() {
    init_platform();
    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[512], time_str[40], mode_label[20];
    XTime tStart, tNow;

    printf("\n--- SYSTEME DE TEST RO (BORDEAUX) ---\n");
    sleep(2); // Pause initiale pour la stabilitť

    XTime_GetTime(&tStart);

    while(1) {
        // Tentative de re-montage seulement au dťbut d'un nouveau cycle
        if (sd_present == 0) {
            if (f_mount(&fatfs, "0:/", 0) == FR_OK) {
                sd_present = 1;
                printf("[SD] Carte detectee.\n");
            }
        }

        printf("\n>>> CYCLE %06d\n", cycle_count);

        for (k = 0; k < 6; k++) {
            // ATTENTE DU FPGA (Indťpendant de la SD)
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;
            sprintf(time_str, "%02dh:%02dm:%02ds", (int)elapsed/3600, ((int)elapsed%3600)/60, (int)elapsed%60);

            if (k < 3) sprintf(mode_label, "RO_B %d", k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE %s | %s\n", time_str, mode_label);

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;

                // --- LECTURE REGISTRE ---
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                float freq_mhz = (float)frequency_32bit / 1000000.0;
                int global_id = (k * 4) + ro_idx + 1;

                // --- 1. AFFICHAGE CONSOLE (D'ABORD !) ---
                printf("    RO %d : %.3f MHz\n", global_id, freq_mhz);

                // --- 2. ECRITURE SD (SEULEMENT SI DISPONIBLE) ---
                if (sd_present == 1) {
                    sprintf(buffer, "%d;%s;Mode %d;RO %d;%.3f\n",
                            cycle_count, time_str, k + 1, global_id, freq_mhz);
                    try_write_sd(buffer);
                }
            }
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }
        cycle_count++;
    }
    return 0;
}
