#include <stdio.h>
#include "platform.h"
#include "xil_printf.h"
#include "xil_io.h"
#include "sleep.h"

// Dķfinition des adresses de ton IP AXI (Ó vķrifier dans Vivado Address Editor)
#define BASE_ADDR      0xA0000000  // Adresse de base de ton IP
#define REG_DATA       (BASE_ADDR + 0)  // Registre de lecture (Octet)
#define REG_STATUS     (BASE_ADDR + 4)  // Registre de statut (Bit 0 = Allow/Ready)
#define REG_CONTROL    (BASE_ADDR + 8)  // Registre de contr¶le (Bit 0 = Done)

int main() {
    init_platform();

    u32 brute_val;
    u32 ro_32bit;
    float freq_mhz;
    int cycle = 0;

    print("--- Demarrage du systeme de mesure ---\n\r");

    while(1) {
        printf("CYCLE N %03d\n\r", cycle);

        // On boucle sur les 6 ROs (comme prķvu dans ton Gen_mode)
        for (int k = 0; k < 6; k++) {
            ro_32bit = 0;

            // Chaque RO envoie 4 octets pour former un mot de 32 bits
            for (int byte = 0; byte < 4; byte++) {

                // 1. ATTENTE : On attend que le FPGA dise "Donnķe disponible"
                // On boucle tant que le bit 0 du registre de statut est Ó 0
                while ((Xil_In32(REG_STATUS) & 0x01) == 0);

                // 2. LECTURE : On rķcupĶre l'octet sur le bus
                brute_val = Xil_In32(REG_DATA) & 0xFF;

                // Reconstruction du mot de 32 bits (Little Endian)
                ro_32bit |= (brute_val << (byte * 8));

                // 3. HANDSHAKE : On envoie le signal "DONE" au FPGA
                // On crķe une impulsion (1 puis 0) sur le bit 0 du registre de contr¶le
                Xil_Out32(REG_CONTROL, 1);
                Xil_Out32(REG_CONTROL, 0);
            }

            // Calcul de la frķquence en MHz
            freq_mhz = (float)ro_32bit / 1000000.0f;
            printf("  RO %d : %.3f MHz\n\r", k, freq_mhz);
        }

        cycle++;
        // Petite pause pour ne pas saturer la console UART
        usleep(100000);
    }

    cleanup_platform();
    return 0;
}
