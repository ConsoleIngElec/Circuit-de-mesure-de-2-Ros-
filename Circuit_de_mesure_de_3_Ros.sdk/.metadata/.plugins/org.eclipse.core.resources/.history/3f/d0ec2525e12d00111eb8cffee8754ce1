#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xtime_l.h"
#include "sleep.h"

#include "main.h"
#include "acquisition.h"
#include "sd_logger.h"
#include "pmic.h"

int main() {
    init_platform();

    int i;
    int cycle_count = 1;
    XTime tStart;

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs       *\n");
    printf("* Societe   : Universite de Bordeaux                   *\n");
    printf("* Ingenieur : Console MBOUBA                           *\n");
    printf("********************************************************\n");


    // --- Initialisation PMIC ---
    printf("[PMIC] Initialisation... ");
    set_channel_IIC_MUX(IIC_MUX_ADDR, IIC_MUX_PMIC_CHANNEL);
    set_PMIC_page(0xD);       // LOOP D : VCCINT
    set_Vmax(VCCINT_VMAX);          // Seuil max de sťcuritť : 0.90V
    set_resolution(VCCINT_RESOLUTION);        // Rťsolution -8 (3.906 mV/step) par dťfaut
    set_voltage(VCCINT_VOLTAGE);       // Tension initiale VCCINT : 0.85V
    printf("[OK]\n\r");


    // --- Initialisation SD ---
    printf("[SD] Initialisation... ");
    if (remount_sd()) {
        sd_logger_init();
        printf("[OK]\n\r");
        write_header();
    } else {
        printf("[ERREUR] Carte SD absente. Mode console uniquement.\n\r");
    }

    XTime_GetTime(&tStart);

    while (1) {

        check_sd_card();

        printf("\n\n>>> DEBUT DU CYCLE N %06d", cycle_count);
        printf(" | SD : %s\n", sd_ready ? "[OK]" : "[ABSENTE]");

        for (i = 0; i < NB_RO;    i++) freq_all[i]    = 0.0f;
        for (i = 0; i < NB_MODES; i++) {
            elapsed_mode[i] = 0.0;
            strcpy(time_mode[i], "00h:00min:00s");
        }

        run_capture_cycle(cycle_count, tStart);

        write_data_line(cycle_count);

        printf(">>> Fin du cycle %06d. En attente de la pause thermique (300s)...\n",
               cycle_count);

        for (i = 0; i < 60; i++) {
            usleep(5000000);
            check_sd_card();
        }

        cycle_count++;
    }

    cleanup_platform();
    return 0;
}
