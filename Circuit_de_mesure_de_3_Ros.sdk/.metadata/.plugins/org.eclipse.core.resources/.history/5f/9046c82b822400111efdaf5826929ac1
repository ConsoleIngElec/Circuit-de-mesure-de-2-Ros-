#include <stdio.h>
#include <string.h>
#include "platform.h"
#include "xparameters.h"
#include "xil_io.h"
#include "xsdps.h"
#include "ff.h"
#include "xtime_l.h"
#include "sleep.h"

#define BASE_ADDR          XPAR_IP_CONVERSION_AXI_0_S00_AXI_BASEADDR
#define REG_DATA_OFFSET    0
#define REG_ALLOW_OFFSET   4
#define REG_DONE_OFFSET    8

static FATFS fatfs;
char *log_file = "Veillissement_des_transistors.CSV";
int sd_was_present = 0;

// --- FORMATAGE DU TEMPS ---
void format_time(double total_seconds, char* out_str) {
    int days = (int)total_seconds / 86400;
    int rest = (int)total_seconds % 86400;
    int h = rest / 3600, m = (rest % 3600) / 60, s = rest % 60;
    if (days > 0) sprintf(out_str, "%02dj:%02dh:%02dmin:%02ds", days, h, m, s);
    else sprintf(out_str, "%02dh:%02dmin:%02ds", h, m, s);
}

// --- ECRITURE SUR SD SECURISEE ---
void write_to_sd(char *filename, char *data) {
    FIL fil;
    UINT bw;
    FRESULT res;

    // 1. On essaie d'ouvrir RAPIDEMENT. Si la carte n'est pas lŕ, l'erreur est immédiate.
    res = f_open(&fil, filename, FA_WRITE | FA_OPEN_APPEND);

    if (res == FR_OK) {
        if (sd_was_present == 0) {
            printf("\n  [INFO] Carte SD detectee ! Reprise de l'ecriture.\n");
            sd_was_present = 1;
        }
        f_write(&fil, data, strlen(data), &bw);
        f_close(&fil);
    } else {
        // 2. Si erreur, on ne bloque pas le CPU.
        if (sd_was_present == 1) {
            printf("\n  [!!! ALERTE SD !!!] Carte retiree. Affichage console uniquement.\n");
            sd_was_present = 0;
            f_mount(NULL, "0:/", 0); // On demonte proprement pour eviter les bugs
        }

        // 3. On tente un remontage léger uniquement de temps en temps (tous les cycles)
        // pour ne pas ralentir la lecture des registres.
    }
}

int main() {
    init_platform();
    u32 byte_read, frequency_32bit;
    int k, ro_idx, b;
    int cycle_count = 1;
    char buffer[512], time_str[40], mode_label[20];
    XTime tStart, tNow;

    printf("\n******************************************************\n");
    printf("* SYSTEME DE CARACTERISATION AUTOMATISEE DES ROs    *\n");
    printf("******************************************************\n");

    // Montage initial
    if (f_mount(&fatfs, "0:/", 1) == FR_OK) {
        sd_was_present = 1;
        printf("[SD CARD] OK : Carte prete.\n");
        write_to_sd(log_file, "Cycle;Temps_Texte;Temps_Sec;Mode;Label;RO_Global_ID;Freq_MHz\n");
    } else {
        printf("[SD CARD] ATTENTION : Carte absente. Mode console seul.\n");
        sd_was_present = 0;
    }

    XTime_GetTime(&tStart);

    while(1) {
        printf("\n\n>>> DEBUT DU CYCLE N %06d\n", cycle_count);

        for (k = 0; k < 6; k++) {
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 0);

            XTime_GetTime(&tNow);
            double elapsed = (double)(tNow - tStart) / COUNTS_PER_SECOND;
            format_time(elapsed, time_str);

            if (k < 3) sprintf(mode_label, "RO_B %d", k + 1);
            else       sprintf(mode_label, "RO_LP %d", k - 2);

            printf("\n  CAPTURE %06d | %s | Mode %d: %s\n", cycle_count, time_str, k + 1, mode_label);
            printf("  --------------------------------------------------\n");

            for (ro_idx = 0; ro_idx < 4; ro_idx++) {
                frequency_32bit = 0;

                // LECTURE DU REGISTRE (Priorité absolue)
                for (b = 0; b < 4; b++) {
                    byte_read = Xil_In32(BASE_ADDR + REG_DATA_OFFSET) & 0xFF;
                    frequency_32bit |= (byte_read << (b * 8));
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 1);
                    Xil_Out32(BASE_ADDR + REG_DONE_OFFSET, 0);
                    for(volatile int d = 0; d < 500; d++);
                }

                float freq_mhz = (float)frequency_32bit / 1000000.0;
                int global_id = (k * 4) + ro_idx + 1;

                // Affichage Console (Indépendant de la SD)
                if (frequency_32bit >= 1000000000)
                    printf("    RO %d : %.3f GHz\n", global_id, freq_mhz / 1000.0);
                else
                    printf("    RO %d : %.3f MHz\n", global_id, freq_mhz);

                // Tentative d'écriture SD (Si elle échoue, elle rend la main tout de suite)
                sprintf(buffer, "%d;%s;%.0f;Mode %d;%s;RO %d;%.3f\n",
                        cycle_count, time_str, elapsed, k + 1, mode_label, global_id, freq_mhz);
                write_to_sd(log_file, buffer);
            }

            printf("\n");
            while ((Xil_In32(BASE_ADDR + REG_ALLOW_OFFSET) & 0x01) == 1);
        }

        // Si la carte a été remise pendant la pause, on essaie de la remonter ici
        if (sd_was_present == 0) {
            f_mount(&fatfs, "0:/", 1);
        }

        printf(">>> Fin du cycle %06d. En attente de la pause thermique (300s)...\n", cycle_count);
        cycle_count++;
    }
    return 0;
}
